[00:15:28.631] Server  LOG     rawText: "[\n  {\n    \"question\": \"According to the article, from whom did the Borjigin clan originate?\",\n    \"options\": [\"Batachikhan\", \"Bodonchar Munkhag\", \"Dobu Mergen\", \"Khawul Khaan\"],\n    \"answer\": \"Bodonchar Munkhag\"\n  },\n  {\n    \"question\": \"Which individual is identified as the ancestor of Chinggis Khaan's 'anda' Jamukha?\",\n    \"options\": [\"Bodonchar Munkhag\", \"Jajiradai\", \"Alun-gua\", \"Malig Bayud\"],\n    \"answer\": \"Jajiradai\"\n  },\n  {\n    \"question\": \"From whom did the Taichuud clan originate?\",\n    \"options\": [\"Khaidu\", \"Tumbinai Setzen\", \"Chirkhai Lyanhua\", \"Khachi Khulug\"],\n    \"answer\": \"Chirkhai Lyanhua\"\n  },\n  {\n    \"question\": \"What was the relationship between Khawul Khaan and Yesukhei Baatar (Chinggis Khaan's father)?\",\n    \"options\": [\"Yesukhei Baatar was Khawul Khaan's eldest son.\", \"Yesukhei Baatar was Khawul Khaan's second son.\", \"Yesukhei Baatar was Khawul Khaan's grandson.\", \"Yesukhei Baatar was Khawul Khaan's nephew.\"],\n    \"answer\": \"Yesukhei Baatar was Khawul Khaan's grandson.\"\n  },\n  {\n    \"question\": \"How did Alun-gua explain the birth of her three sons after Dobu Mergen's death?\",\n    \"options\": [\"She said they were from a servant of the Malig Bayud clan.\", \"She attributed them to a white-yellow man from the sky who entered at night.\", \"She claimed they were born from Dobu Mergen's brother.\", \"She said they were from Bodonchar Munkhag.\"],\n    \"answer\": \"She attributed them to a white-yellow man from the sky who entered at night.\"\n  }\n]"
[00:15:28.631] Server  LOG     cleanedText: "[\n  {\n    \"question\": \"According to the article, from whom did the Borjigin clan originate?\",\n    \"options\": [\"Batachikhan\", \"Bodonchar Munkhag\", \"Dobu Mergen\", \"Khawul Khaan\"],\n    \"answer\": \"Bodonchar Munkhag\"\n  },\n  {\n    \"question\": \"Which individual is identified as the ancestor of Chinggis Khaan's 'anda' Jamukha?\",\n    \"options\": [\"Bodonchar Munkhag\", \"Jajiradai\", \"Alun-gua\", \"Malig Bayud\"],\n    \"answer\": \"Jajiradai\"\n  },\n  {\n    \"question\": \"From whom did the Taichuud clan originate?\",\n    \"options\": [\"Khaidu\", \"Tumbinai Setzen\", \"Chirkhai Lyanhua\", \"Khachi Khulug\"],\n    \"answer\": \"Chirkhai Lyanhua\"\n  },\n  {\n    \"question\": \"What was the relationship between Khawul Khaan and Yesukhei Baatar (Chinggis Khaan's father)?\",\n    \"options\": [\"Yesukhei Baatar was Khawul Khaan's eldest son.\", \"Yesukhei Baatar was Khawul Khaan's second son.\", \"Yesukhei Baatar was Khawul Khaan's grandson.\", \"Yesukhei Baatar was Khawul Khaan's nephew.\"],\n    \"answer\": \"Yesukhei Baatar was Khawul Khaan's grandson.\"\n  },\n  {\n    \"question\": \"How did Alun-gua explain the birth of her three sons after Dobu Mergen's death?\",\n    \"options\": [\"She said they were from a servant of the Malig Bayud clan.\", \"She attributed them to a white-yellow man from the sky who entered at night.\", \"She claimed they were born from Dobu Mergen's brother.\", \"She said they were from Bodonchar Munkhag.\"],\n    \"answer\": \"She attributed them to a white-yellow man from the sky who entered at night.\"\n  }\n]"
